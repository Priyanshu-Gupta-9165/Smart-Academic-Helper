{
  "manifest_version": 3,
  "name": "AI Presentation Agent",
  "version": "1.0",
  "description": "Create professional presentations with AI assistance",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://docs.google.com/presentation/*",
    "https://*.office.com/powerpoint*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://pixabay.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/presentation/*",
        "https://*.office.com/powerpoint*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png"
    },
    "default_title": "Open AI Presentation Agent"
  }
}